{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "{data/posts.json,public/**,images/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/tmdb-sync",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/webhook/telegram",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "/api/index.js"
    },
    {
      "src": "/store-images/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/loja",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
